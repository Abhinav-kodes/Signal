{
  "name": "@signal/electron-client",
  "version": "1.0.0",
  "description": "A custom Signal browser built with Electron",
  "author": "Abhinav <abhinavsingh717073@gmail.com>",
  "homepage": "https://github.com/Abhinav-kodes/Signal",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder -lw"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.signal.browser",
    "productName": "Signal",
    "executableName": "signal-browser", 
    "protocols": [
      {
        "name": "Signal Deep Link",
        "schemes": ["signal"]
      }
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "build/icons",
        "to": "build/icons",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "out/**/*"
    ],
    "linux": {
      "icon": "build/icons",
      "target": ["AppImage", "deb"],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "deb": {
      "packageCategory": "utils",
      "priority": "optional",
      "depends": ["libnss3", "libatk-bridge2.0-0", "libgtk-3-0"]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Signal"
    }
  }
}