{
  "manifest_version": 3,
  "name": "Signal",
  "version": "1.0.0",
  "description": "Track any web element. Point, click, done.",
  "permissions": ["activeTab", "tabs", "cookies"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open in Signal"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "48": "icon48.png"
  }
}
