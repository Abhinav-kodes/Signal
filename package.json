{
  "name": "signal-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
"scripts": {
    "dev:server": "cd apps/server && bun run dev",
    "dev:client": "cd apps/electron-client && bun run dev",
    "dev:ext": "cd apps/browser-extension && bun run dev",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "typescript-eslint": "^8.56.1"
  }
}